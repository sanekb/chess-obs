{
  "lock": false,
  "imports": {
    "@/": "./src/",
    "@hono/hono": "jsr:@hono/hono@^4.12.23",
    "@preact/signals": "npm:@preact/signals@^2.9.1",
    "@preact/signals-core": "npm:@preact/signals-core@^1.14.2",
    "clsx": "npm:clsx@^2.1.1",
    "preact": "npm:preact@^10.29.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "checkJs": true,
    "noImplicitAny": false
  },
  "tasks": {
    "build": "deno fmt && deno bundle src/client/app.jsx -o public/app.js --minify",
    "tailwind": "tailwindcss -i ./src/client/app.css -o ./public/app.css",
    "run": "deno run -A --env-file=.env src/server/app.js",
    "dev": "deno task build && deno task tailwind && deno task run"
  }
}
